{
  "name": "xray-tunnel",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {"version": "latest"}
  },
  "forwardPorts": [10000],
  "postStartCommand": "bash /workspaces/xray-tunnel/start.sh",
  "portsAttributes": {
    "10000": {"label": "Xray VMess", "onAutoForward": "silent"}
  }
}
